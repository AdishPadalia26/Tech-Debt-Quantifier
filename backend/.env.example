DATABASE_URL=sqlite:///./techdebt.db
REDIS_URL=redis://localhost:6379
OPENAI_API_KEY=your-openai-key-here
GITHUB_TOKEN=your-github-token-here
ENGINEER_HOURLY_RATE=85

# LLM Settings
LLM_PROVIDER=ollama
OLLAMA_MODEL=qwen3.5:latest
OLLAMA_BASE_URL=http://localhost:11434/v1
OLLAMA_API_KEY=ollama
HF_TOKEN=your-huggingface-token
HF_MODEL_ID=Qwen/Qwen2.5-7B-Instruct
HF_FALLBACK_MODEL=TinyLlama/TinyLlama-1.1B-Chat-v1.0

# Slack Integration
SLACK_BOT_TOKEN=xoxb-your-token
SLACK_DEFAULT_CHANNEL=#tech-debt

# Jira Integration
JIRA_SERVER=https://yourcompany.atlassian.net
JIRA_EMAIL=your-email@company.com
JIRA_API_TOKEN=your-api-token
JIRA_PROJECT_KEY=TD

# GitHub OAuth
GITHUB_CLIENT_ID=your-client-id
GITHUB_CLIENT_SECRET=your-client-secret
GITHUB_OAUTH_CALLBACK_URL=http://localhost:8000/auth/github/callback
JWT_SECRET=super-secret-dev-key
JWT_ALG=HS256
FRONTEND_ORIGIN=http://localhost:3000
